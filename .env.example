# Copy this file to .env and fill in your provider settings.
# Never commit .env.

# Required. Supported values: openai, anthropic, azure.
COPILOT_BYOK_TYPE=openai

# Required. Replace with your provider endpoint.
COPILOT_BYOK_BASE_URL=https://your-provider.example.com/v1

# Usually required unless your provider does not need an API key.
COPILOT_BYOK_API_KEY=your-api-key-here

# Optional. If set, bearer token takes precedence over API key.
# COPILOT_BYOK_BEARER_TOKEN=

# Required unless COPILOT_BYOK_MODEL_ID is set.
COPILOT_BYOK_MODEL=your-model-name

# Optional advanced mapping.
# COPILOT_BYOK_MODEL_ID=
# COPILOT_BYOK_WIRE_MODEL=
# COPILOT_BYOK_WIRE_API=
# COPILOT_BYOK_MAX_PROMPT_TOKENS=
# COPILOT_BYOK_MAX_OUTPUT_TOKENS=

# Optional async runner settings.
# COPILOT_BYOK_RUNS_DIR=
# COPILOT_BYOK_MAX_WALL=600
# COPILOT_BYOK_IDLE_TIMEOUT=120
# COPILOT_BYOK_HEARTBEAT=15
# COPILOT_BYOK_KILL_GRACE=10
